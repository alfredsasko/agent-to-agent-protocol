# Google Cloud / Vertex AI
GOOGLE_CLOUD_PROJECT=YOUR_GOOGLE_CLOUD_PROJECT_ID
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=true

# LiteLLM Vertex AI settings
VERTEXAI_PROJECT=YOUR_GOOGLE_CLOUD_PROJECT_ID
VERTEXAI_LOCATION=global

# Model configuration
POLICY_AGENT_BACKEND=google
ANTHROPIC_VERTEX_MODEL=claude-haiku-4-5@20251001
ANTHROPIC_VERTEX_LOCATION=global
POLICY_GOOGLE_VERTEX_MODEL=gemini-2.5-flash-lite
POLICY_GOOGLE_VERTEX_LOCATION=global
PROVIDER_MODEL=openai/gpt-oss-120b-maas
PROVIDER_VERTEX_LOCATION=global
RESEARCH_MODEL=gemini-2.5-flash
RESEARCH_VERTEX_LOCATION=global
HEALTHCARE_MODEL=gemini-2.5-flash
HEALTHCARE_VERTEX_LOCATION=global

# Agent Network Configuration
AGENT_HOST="localhost"

# Agent Ports
POLICY_AGENT_PORT=9999
RESEARCH_AGENT_PORT=9998
PROVIDER_AGENT_PORT=9997
HEALTHCARE_AGENT_PORT=9996

# Optional: override the included policy document
# POLICY_DOCUMENT_PATH=/absolute/path/to/policy.pdf
